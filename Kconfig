# ESP NMEA Bridge application configuration

mainmenu "ESP NMEA Bridge"

menu "ESP NMEA-0183 serial bridge"

config ESP_NMEA_BRIDGE_AP_ENABLE
	bool "Enable ESP32 SoftAP"
	default y

config ESP_NMEA_BRIDGE_STA_ENABLE
	bool "Enable Wi-Fi station mode"
	default y

config ESP_NMEA_BRIDGE_TCP_NMEA_SERVER_ENABLE
	bool "Enable TCP NMEA server"
	default y

config ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_ENABLE
	bool "Enable TCP NMEA client"
	default y
	depends on ESP_NMEA_BRIDGE_STA_ENABLE

config ESP_NMEA_BRIDGE_STATUS_LED_ENABLE
	bool "Enable status LED observer"
	default y
	select LED_STRIP
	help
	  Enable the optional status LED observer. When enabled, the observer
	  looks for a NeoPixel-compatible LED strip through the led-strip
	  devicetree alias and renders NMEA connection state. Missing or
	  non-ready LED hardware is non-fatal.

config ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_HOST
	string "TCP NMEA server IPv4 address"
	default ""
	depends on ESP_NMEA_BRIDGE_TCP_NMEA_CLIENT_ENABLE
	help
	  IPv4 address of the upstream TCP NMEA server. Leave empty to use the
	  DHCP gateway learned on the STA interface, useful when the ESP connects
	  directly to a Raspberry Pi/OpenPlotter hotspot.

config ESP_NMEA_BRIDGE_AP_SSID
	string "SoftAP SSID"
	default "ESP-NMEA0183"

config ESP_NMEA_BRIDGE_AP_PSK
	string "SoftAP WPA2 PSK password"
	default "ChangeMe1234"
	help
	  Prototype default only. Override in a local/pristine overlay for real use.
	  Leave empty to start an open SoftAP.

config ESP_NMEA_BRIDGE_STA_SSID
	string "STA target AP SSID"
	default ""

config ESP_NMEA_BRIDGE_STA_PSK
	string "STA target AP password"
	default ""

config ESP_NMEA_BRIDGE_STA_ROTATE_MAC
	bool "Rotate STA MAC address on boot"
	default y
	depends on ESP_NMEA_BRIDGE_STA_ENABLE
	help
	  Use a random locally administered STA MAC address on each boot. This
	  avoids stale station state on APs that keep the previous association
	  after the ESP resets without sending a deauthentication frame.

config ESP_NMEA_BRIDGE_TCP_NMEA_PORT
	int "TCP NMEA port"
	default 10110

config ESP_NMEA_BRIDGE_TCP_NMEA_SERVER_MAX_CLIENTS
	int "Maximum TCP NMEA server clients"
	default 3
	range 1 8

config ESP_NMEA_BRIDGE_NMEA_FRAME_MAX_LEN
	int "Maximum NMEA frame length"
	default 128
	range 32 512

config ESP_NMEA_BRIDGE_INGEST_QUEUE_DEPTH
	int "NMEA ingest queue depth"
	default 32
	range 2 256

config ESP_NMEA_BRIDGE_SINK_QUEUE_DEPTH
	int "Per-sink NMEA queue depth"
	default 16
	range 2 128

config ESP_NMEA_BRIDGE_AP_IP_ADDRESS
	string "SoftAP IPv4 address"
	default "192.168.4.1"

config ESP_NMEA_BRIDGE_AP_NETMASK
	string "SoftAP IPv4 netmask"
	default "255.255.255.0"

endmenu

source "Kconfig.zephyr"
